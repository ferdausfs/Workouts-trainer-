# PulseFit AI - Environment Configuration Template
# Copy to .env and fill in real values

# Firebase
FIREBASE_API_KEY=your_android_api_key
FIREBASE_APP_ID=your_android_app_id
FIREBASE_PROJECT_ID=pulsefit-ai
FIREBASE_SENDER_ID=your_sender_id
FIREBASE_STORAGE_BUCKET=pulsefit-ai.appspot.com

# Backend API
API_BASE_URL=https://api.pulsefit.ai/v1
API_KEY=your_backend_api_key

# AI Coach (optional - OpenAI compatible)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# RevenueCat (in-app purchases)
REVENUECAT_API_KEY_ANDROID=your_revenuecat_android_key

# Sentry (error monitoring)
SENTRY_DSN=https://...@sentry.io/...
